# Database Connection String (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tabletop?schema=public"

# Server Port
PORT=3001

# Cryptographic Secret for QR code table tokens
JWT_SECRET="tabletop-super-secret-key-change-this-in-production"

# Frontend Origin for CORS and QR code URLs
FRONTEND_URL="http://localhost:3000"
