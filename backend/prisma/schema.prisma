datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum OperationalMode {
  FULL_SERVICE
  SELF_SERVICE
}

enum PaymentCollectionMode {
  PRE_PAY
  POST_PAY
}

enum EstablishmentType {
  RESTAURANT
  HOTEL
}

enum TableStatus {
  VACANT
  OCCUPIED
}

enum SessionStatus {
  ACTIVE
  CLOSED
}

enum OrderStatus {
  PENDING      // Collaborative active cart status
  PAYMENT_PENDING // Direct Checkout Verification
  NEW          // Submitted to kitchen
  PREPARING
  READY_TO_SERVE
  COMPLETED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  VOIDED
}

model Restaurant {
  id              String          @id @default(uuid())
  name              String
  passcodeHash      String?
  operationalMode   OperationalMode   @default(FULL_SERVICE)
  paymentMode       PaymentCollectionMode @default(POST_PAY)
  establishmentType EstablishmentType @default(RESTAURANT)
  roomServiceFee    Decimal           @default(0.00) @db.Decimal(10, 2)
  taxRate           Decimal           @db.Decimal(5, 4) // e.g. 0.0825 for 8.25%
  upiId             String?
  merchantName      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tables            Table[]
  menuItems         MenuItem[]
}

model Table {
  id           String      @id @default(uuid())
  number       String
  token        String      @unique // Secure signed token containing table details
  status       TableStatus @default(VACANT)
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sessions     Session[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([restaurantId, number])
  @@index([restaurantId])
}

model Session {
  id           String        @id @default(uuid())
  tableId      String
  table        Table         @relation(fields: [tableId], references: [id], onDelete: Cascade)
  restaurantId String
  status       SessionStatus @default(ACTIVE)
  orders       Order[]
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  closedAt     DateTime?

  @@index([tableId])
  @@index([restaurantId, status])
}

model MenuItem {
  id             String      @id @default(uuid())
  name           String
  description    String?
  price          Decimal     @db.Decimal(10, 2)
  halfPrice      Decimal?    @db.Decimal(10, 2)
  hasHalfPortion Boolean     @default(false)
  category       String      @default("Main Course")
  imageUrl       String?     // Cloudinary URL for the dish photo
  isAvailable    Boolean     @default(true)
  allowsDietary  Boolean     @default(true) // Whether the dish can be customized for dietary needs (e.g. Jain)
  restaurantId   String
  restaurant     Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([restaurantId])
}

model Order {
  id            String      @id @default(uuid())
  sessionId     String
  session       Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  status        OrderStatus @default(PENDING)
  paymentMethod String?
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([sessionId])
}

model OrderItem {
  id            String             @id @default(uuid())
  orderId       String
  order         Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId    String
  menuItem      MenuItem           @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  quantity      Decimal            @db.Decimal(10, 2) // Enabled fractional quantities (e.g. 1.5 or 0.5)
  price         Decimal            @db.Decimal(10, 2) // Captured price at checkout/order time to avoid menu updates affecting past orders
  modifications String[]           // Array of user requests like "No onions", "Extra cheese"
  payments      OrderItemPayment[]
  createdAt     DateTime           @default(now())

  @@index([orderId])
}

model Transaction {
  id            String             @id @default(uuid())
  sessionId     String
  session       Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  amount        Decimal            @db.Decimal(10, 2)
  taxPaid       Decimal            @db.Decimal(10, 2)
  status        TransactionStatus  @default(PENDING)
  paymentMethod String?
  customerName       String?            // Metadata tracking for split billing
  customerPhone      String?            // Metadata tracking for split billing
  deliveryFeeApplied Decimal            @db.Decimal(10, 2) @default(0.00)
  razorpayOrderId    String?            @unique
  razorpayPaymentId  String?            @unique
  razorpaySignature  String?
  paymentItems       OrderItemPayment[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([sessionId])
}

model OrderItemPayment {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  orderItemId   String
  orderItem     OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  quantityPaid  Decimal     @db.Decimal(10, 2) // Quantity of this OrderItem paid in this transaction (allows decimal splits)
  amount        Decimal     @db.Decimal(10, 2) // Calculated subtotal for this portion
  taxFraction   Decimal     @db.Decimal(10, 4) // Exact tax portion attributed to this split item
  createdAt     DateTime    @default(now())

  @@index([transactionId])
  @@index([orderItemId])
}
