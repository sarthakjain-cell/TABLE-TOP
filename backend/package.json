{
  "name": "tabletop-backend",
  "version": "1.0.0",
  "description": "Table Top real-time restaurant ordering and management backend",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npx prisma db push --accept-data-loss && prisma generate && tsc",
    "start": "npx prisma generate && node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "jest",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "@prisma/client": "^5.14.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "decimal.js": "^10.4.3",
    "dotenv": "^17.4.2",
    "fastify": "^4.27.0",
    "node-cache": "^5.1.2",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.14.0",
    "razorpay": "^2.9.6",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.12",
    "@types/node-cache": "^4.1.3",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
